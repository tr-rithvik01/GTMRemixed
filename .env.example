# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and never committed.

# Email subscribe API endpoint (used by HeroEmailForm and NewsletterSignup).
# Point this at your provider's API route (ConvertKit, Beehiiv, Mailchimp, etc.)
# or a Cloudflare Worker proxy.
# PUBLIC_SUBSCRIBE_URL=https://api.yourdomain.com/subscribe
