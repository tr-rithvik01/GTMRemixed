---
/**
 * ArticleCard.astro — standard article card used in grids.
 *
 * WHY .astro (not React)?
 * Article cards in static grids (homepage recent articles, niche hub pages) are
 * pre-rendered HTML. No interactive state needed. Using Astro keeps them out of
 * the JS bundle entirely — better Core Web Vitals.
 *
 * The BlogFilter React island uses its own inline card (ArticleCardInline) so
 * it stays in the same React tree for dynamic re-rendering on filter change.
 *
 * PROPS:
 *   article {Article} — article object from src/data/index.ts
 */

import type { Article } from '../../data/index';
import TagBadge from './TagBadge.astro';
import ImgPlaceholder from './ImgPlaceholder.astro';

interface Props {
  article: Article;
}

const { article } = Astro.props;

// article.date is a human-readable string like "April 18, 2026"
// new Date() parses it correctly in Node.js and modern browsers.
const date = article.date;
---

<article class="article-card">
  <!-- Image area -->
  <a href={`/blog/${article.slug}`} class="article-card-img-link" tabindex="-1" aria-hidden="true">
    <ImgPlaceholder aspect="video" />
  </a>

  <div class="article-card-body">
    <!-- Channel tag -->
    {article.niche && (
      <TagBadge label={article.niche.toUpperCase()} variant="niche" href={`/niches/${article.niche}`} />
    )}

    <!-- Title -->
    <h3 class="article-card-title">
      <a href={`/blog/${article.slug}`} class="article-card-link">
        {article.title}
      </a>
    </h3>

    <!-- Excerpt -->
    <p class="article-card-excerpt">{article.excerpt}</p>

    <!-- Meta row -->
    <div class="article-card-meta">
      <span>{date}</span>
      {article.readTime && (
        <span class="article-card-read-time">{article.readTime} read</span>
      )}
    </div>
  </div>
</article>
