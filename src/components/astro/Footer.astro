---
/**
 * Footer.astro — static site-wide footer.
 * WHY .astro: purely static HTML, zero JS. CSS class names match global.css.
 */

const year = new Date().getFullYear();

const footerLinks = {
  channels: [
    { href: '/niches/seo',       label: 'SEO' },
    { href: '/niches/ppc',       label: 'PPC' },
    { href: '/niches/social',    label: 'Social Media' },
    { href: '/niches/local',     label: 'Local SEO' },
    { href: '/niches/analytics', label: 'Analytics' },
    { href: '/niches/content',   label: 'Content Marketing' },
    { href: '/niches/email',     label: 'Email Marketing' },
    { href: '/niches/cro',       label: 'CRO' },
  ],
  industries: [
    { href: '/industries/saas',         label: 'SaaS' },
    { href: '/industries/ecommerce',    label: 'E-commerce' },
    { href: '/industries/healthcare',   label: 'Healthcare' },
    { href: '/industries/fintech',      label: 'Fintech' },
    { href: '/industries/realestate',   label: 'Real Estate' },
    { href: '/industries/logistics',    label: 'Logistics' },
    { href: '/industries/professional', label: 'Professional Services' },
    { href: '/industries/hospitality',  label: 'Hospitality' },
  ],
  company: [
    { href: '/about',     label: 'About' },
    { href: '/blog',      label: 'Blog' },
    { href: '/resources', label: 'Resources' },
    { href: '/contact',   label: 'Contact' },
  ],
};
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-inner">

      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">GTM Remixed</a>
        <p class="footer-desc">
          Modern go-to-market strategies, tools, and frameworks for B2B teams.
        </p>
        <nav class="footer-social" aria-label="Social media">
          <a href="https://twitter.com/gtmremixed" class="footer-social-link" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.63L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/></svg>
          </a>
          <a href="https://linkedin.com/company/gtmremixed" class="footer-social-link" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </nav>
      </div>

      <!-- Channels -->
      <nav class="footer-col" aria-label="Marketing channels">
        <h3 class="footer-col-title">Channels</h3>
        <ul class="footer-link-list">
          {footerLinks.channels.map(link => (
            <li><a href={link.href} class="footer-link">{link.label}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Industries -->
      <nav class="footer-col" aria-label="Industries">
        <h3 class="footer-col-title">Industries</h3>
        <ul class="footer-link-list">
          {footerLinks.industries.map(link => (
            <li><a href={link.href} class="footer-link">{link.label}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Company -->
      <nav class="footer-col" aria-label="Company">
        <h3 class="footer-col-title">Company</h3>
        <ul class="footer-link-list">
          {footerLinks.company.map(link => (
            <li><a href={link.href} class="footer-link">{link.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p>&copy; {year} GTM Remixed. All rights reserved.</p>
      <nav aria-label="Legal">
        <a href="/privacy" class="footer-link">Privacy Policy</a>
        <a href="/terms"   class="footer-link" style="margin-left: 16px">Terms</a>
      </nav>
    </div>
  </div>
</footer>
